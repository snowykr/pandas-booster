{
  "typeCheckingMode": "standard",
  "include": ["python/pandas_booster"],
  "exclude": [
    ".idea",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    "benches",
    "tests",
    "target"
  ],
  "reportExplicitAny": "none",
  "reportMissingTypeArgument": "none",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["python"]
    }
  ]
}
